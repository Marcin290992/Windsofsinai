---
// TextReveal.astro
// Użycie: <TextReveal lines={["Linia pierwsza", "Linia druga"]} label="Opcjonalny label" />
interface Props {
  lines: string[];
  label?: string;
}
const { lines, label } = Astro.props;
---

<div class="reveal-block">
  {label && <p class="reveal-label">{label}</p>}
  {lines.map((line) => (
    <div class="reveal-line">
      <span set:html={line} />
    </div>
  ))}
</div>

<style>
  .reveal-block {
    overflow: hidden;
  }

  .reveal-label {
    font-family: var(--f-mono);
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-gold-dim);
    margin-bottom: 1.5rem;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.6s ease, transform 0.6s var(--ease-expo);
  }

  .reveal-line {
    overflow: hidden;
    line-height: 1.08;
  }

  .reveal-line span {
    display: block;
    font-family: var(--f-display);
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 300;
    font-style: italic;
    color: var(--c-white);
    letter-spacing: -0.02em;
    transform: translateY(110%) skewY(6deg);
    opacity: 0;
    transition:
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.7s ease;
  }

  /* Stagger delays */
  .reveal-line:nth-child(1) span { transition-delay: 0s; }
  .reveal-line:nth-child(2) span { transition-delay: 0.12s; }
  .reveal-line:nth-child(3) span { transition-delay: 0.24s; }
  .reveal-line:nth-child(4) span { transition-delay: 0.36s; }
  .reveal-line:nth-child(5) span { transition-delay: 0.48s; }
  .reveal-line:nth-child(6) span { transition-delay: 0.60s; }

  /* Visible state */
  .reveal-block.is-visible .reveal-label {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-block.is-visible .reveal-line span {
    transform: translateY(0) skewY(0deg);
    opacity: 1;
  }
</style>

<script>
  function initReveal() {
    const blocks = document.querySelectorAll('.reveal-block');
    const isMobile = window.innerWidth <= 900;

    blocks.forEach((block) => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              if (isMobile) {
                setTimeout(() => block.classList.add('is-visible'), 0);
              } else {
                block.classList.add('is-visible');
              }
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: isMobile ? 0.15 : 0.2,
          rootMargin: isMobile ? '0px 0px -30px 0px' : '0px 0px -60px 0px'
        }
      );
      observer.observe(block);
    });
  }

  document.addEventListener('astro:page-load', initReveal);
  if (document.readyState !== 'loading') initReveal();
</script>
