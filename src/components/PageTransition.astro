---
// PageTransition.astro
// Strip curtain page transition — always plays, including same-path navigation.
---

<style is:global>
  #pt-overlay {
    position: fixed;
    inset: 0;
    z-index: 99990;
    pointer-events: none;
    overflow: hidden;
    contain: strict;
  }

  .pt-strip {
    position: absolute;
    top: 0;
    bottom: 0;
    background: #E8E0D0;
    transform: scaleY(0);
    transform-origin: bottom center;
    will-change: transform;
  }

  .pt-strip:nth-child(1) { left: 0;     right: 66.2%; }
  .pt-strip:nth-child(2) { left: 33.1%; right: 33.1%; }
  .pt-strip:nth-child(3) { left: 66.2%; right: 0;     }

  /* Kill ALL browser View Transition animations — our overlay handles everything */
  ::view-transition-group(*),
  ::view-transition-image-pair(*) {
    animation: none !important;
    mix-blend-mode: normal !important;
  }
  ::view-transition-old(*),
  ::view-transition-new(*) {
    animation: none !important;
    opacity: 0 !important;
    mix-blend-mode: normal !important;
  }

</style>

<div id="pt-overlay" aria-hidden="true" transition:persist>
  <div class="pt-strip"></div>
  <div class="pt-strip"></div>
  <div class="pt-strip"></div>
</div>


<script is:inline>
(function () {
  if (window.__ptBound) return;
  window.__ptBound = true;

  /* ── Timings ───────────────────────────────────────────────── */
  var DESKTOP = { exitDur: 0.62, exitStagger: 0.10, hold: 70,  enterDur: 0.80, enterStagger: 0.10 };
  var MOBILE  = { exitDur: 0.50, exitStagger: 0.08, hold: 40,  enterDur: 0.64, enterStagger: 0.08 };
  var N       = 3;
  var COLOR   = '#E8E0D0';
  var RM_IN   = 140;
  var RM_OUT  = 0.24;

  /* ── Helpers ───────────────────────────────────────────────── */
  function mob() { return !!window.matchMedia?.('(max-width:900px)').matches; }
  function rm()  { return !!window.matchMedia?.('(prefers-reduced-motion:reduce)').matches; }
  function tim() { return mob() ? MOBILE : DESKTOP; }
  function g()   { return window.gsap; }
  function ov()  { return document.getElementById('pt-overlay'); }
  function ss()  { return document.querySelectorAll('.pt-strip'); }

  function totalExitMs(t) {
    if (rm()) return RM_IN + 40;
    return Math.round((t.exitDur + t.exitStagger * (N - 1)) * 1000) + t.hold;
  }

  /* ── Strip state ───────────────────────────────────────────── */
  function paint() { ss().forEach(function(s){ s.style.background = COLOR; }); }

  function coverNow() {
    ss().forEach(function(s){
      s.style.transform = 'scaleY(1)';
      s.style.transformOrigin = 'bottom center';
    });
    var o = ov(); if (o) { o.style.pointerEvents = 'all'; o.style.opacity = '1'; }
  }

  function resetNow() {
    ss().forEach(function(s){
      s.style.transform = 'scaleY(0)';
      s.style.transformOrigin = 'bottom center';
    });
    var o = ov(); if (o) { o.style.pointerEvents = 'none'; o.style.opacity = '1'; o.style.transition = ''; }
  }

  /* ══════════════════════════════════════════════════════════
     before-preparation
  ══════════════════════════════════════════════════════════ */
  document.addEventListener('astro:before-preparation', function(e) {
    var t           = tim();
    window.__ptTim  = t;
    window.__ptDir  = e.direction || 'forward';

    var sw = document.getElementById('scroll-wrapper');
    if (sw) sw.style.overflow = 'hidden';
    if (window.lenis) window.lenis.stop();

    paint();

    if (rm()) {
      coverNow();
      var o = ov();
      if (o) { o.style.opacity = '0'; o.style.transition = 'opacity ' + RM_IN + 'ms ease'; requestAnimationFrame(function(){ o.style.opacity = '1'; }); }
    } else if (g()) {
      g().killTweensOf('.pt-strip');
      g().set('.pt-strip', { scaleY: 0, transformOrigin: 'bottom center' });
      g().to('.pt-strip', { scaleY: 1, duration: t.exitDur, ease: 'sine.inOut', stagger: t.exitStagger });
      ov().style.pointerEvents = 'all';
    } else {
      coverNow();
    }

    if (typeof e.loader === 'function') {
      var orig = e.loader;
      e.loader = function() {
        return Promise.all([orig(), new Promise(function(r){ setTimeout(r, totalExitMs(t)); })]);
      };
    }
  });

  /* ══════════════════════════════════════════════════════════
     before-swap — skip browser snapshot entirely
  ══════════════════════════════════════════════════════════ */
  document.addEventListener('astro:before-swap', function(e) {
    if (e.viewTransition) {
      try { e.viewTransition.skipTransition(); } catch(_) {}
      if (e.viewTransition.ready) e.viewTransition.ready.catch(function(){});
      if (e.viewTransition.finished) e.viewTransition.finished.catch(function(){});
    }

    if (rm()) { coverNow(); return; }

    if (g()) {
      g().killTweensOf('.pt-strip');
      g().set('.pt-strip', { scaleY: 1, transformOrigin: 'bottom center' });
      ov().style.pointerEvents = 'all';
      return;
    }

    coverNow();
  });

  /* ══════════════════════════════════════════════════════════
     after-swap — restore scroll, animate strips/fade UP
  ══════════════════════════════════════════════════════════ */
  document.addEventListener('astro:after-swap', function() {
    var t      = window.__ptTim || tim();
    var isBack = window.__ptDir === 'back';
    window.__ptDir  = undefined;

    /* Restore scroll */
    var sw = document.getElementById('scroll-wrapper');
    if (sw) {
      if (!isBack) sw.scrollTop = 0;
      sw.style.overflow = '';
    }
    if (window.lenis) {
      if (!isBack) window.lenis.scrollTo(0, { immediate: true });
      window.lenis.start();
    }

    /* Close menu */
    var mo = document.getElementById('menuOverlay');
    if (mo) { mo.classList.remove('is-open'); mo.getAnimations().forEach(function(a){ a.cancel(); }); }
    var mt = document.getElementById('menuTrigger');
    if (mt) { mt.classList.remove('is-active'); mt.setAttribute('aria-expanded','false'); }
    var ft = document.getElementById('floatingTrigger');
    if (ft) ft.classList.remove('is-active','menu-open');
    document.body.classList.remove('menu-is-open');

    /* ── Strips up ── */
    if (rm()) {
      var o = ov();
      if (o) { o.style.pointerEvents = 'all'; o.style.transition = 'opacity ' + RM_OUT + 's ease'; o.style.opacity = '0'; }
      setTimeout(resetNow, Math.round(RM_OUT * 1000));
      return;
    }

    if (g()) {
      g().killTweensOf('.pt-strip');
      g().set('.pt-strip', { scaleY: 1, transformOrigin: 'top center' });
      ov().style.pointerEvents = 'all';
      g().to('.pt-strip', {
        scaleY: 0,
        duration: t.enterDur,
        ease: 'sine.inOut',
        stagger: { each: t.enterStagger, from: 'end' },
        onComplete: resetNow,
      });
      return;
    }

    resetNow();
  });

})();
</script>