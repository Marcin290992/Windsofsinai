---
import Navigation from '../components/Navigation.astro';
import EnquiryModal from '../components/EnquiryModal.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title = 'Winds of Sinai' } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, interactive-widget=resizes-visual, viewport-fit=cover" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=IBM+Plex+Mono:wght@400&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=IBM+Plex+Mono:wght@400&display=swap" />


    <!--
      Single inline script — runs in <head>, safe on Netlify.
      Only touches documentElement (always available).
      Never touches document.body (may be null in <head>).
    -->
    <script is:inline>
      (function () {
        // FOUT guard — remove once fonts load
        document.documentElement.classList.add('fonts-loading');
        document.fonts.ready.then(function () {
          document.documentElement.classList.remove('fonts-loading');
          document.documentElement.classList.add('fonts-loaded');
        });

        // --vh: safe to call any time, uses innerHeight not scroll-wrapper
        function setVh() {
          document.documentElement.style.setProperty('--vh', (window.innerHeight * 0.01) + 'px');
        }
        setVh();
        window.addEventListener('resize', setVh);
      })();
    </script>
  </head>

  <body class="bg-[#FAF8F3] text-zinc-900 antialiased">

    <!-- Page transition cover — starts opaque, fades out once CSS+DOM ready -->
    <div id="page-cover" aria-hidden="true"></div>

    <!-- Liquid Glass SVG filter (referenced by [data-liquid-glass] elements) -->
    <svg class="liquid-glass-defs" aria-hidden="true">
      <defs>
        <filter id="liquid-glass" x="-10%" y="-10%" width="120%" height="120%" color-interpolation-filters="sRGB">
          <feTurbulence id="liquid-turb" type="fractalNoise" baseFrequency="0.012 0.014" numOctaves="3" seed="2" result="noise" />
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="18" xChannelSelector="R" yChannelSelector="G" />
        </filter>
        <filter id="liquid-glass-sm" x="-10%" y="-10%" width="120%" height="120%" color-interpolation-filters="sRGB">
          <feTurbulence id="liquid-turb-sm" type="fractalNoise" baseFrequency="0.018 0.02" numOctaves="2" seed="5" result="noise" />
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="10" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
    </svg>

    <Navigation />
    <EnquiryModal />

    <div id="preloader" aria-hidden="true">
      <span id="preloader-text">Winds Of Sinai</span>
    </div>

    <Footer />

    <div class="grid-overlay" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>

    <div id="scroll-wrapper">
      <div id="scroll-content">
        <slot />
      </div>
      <div id="footer-spacer"></div>
    </div>

    <!-- main.js handles: Lenis init, GSAP, preloader animation, SPA lifecycle -->
    <script>
      import '../scripts/main.js';
    </script>

    <!-- Liquid Glass turbulence animation — only runs on hover -->
    <script>
      function initLiquidGlass() {
        const turb   = document.getElementById('liquid-turb')    as SVGElement | null;
        const turbSm = document.getElementById('liquid-turb-sm') as SVGElement | null;
        if (!turb) return;

        let frame = 0;
        let running = false;

        function tick() {
          frame += 0.004;
          turb!.setAttribute('baseFrequency',
            `${(0.012 + Math.sin(frame) * 0.003).toFixed(4)} ${(0.014 + Math.cos(frame * 0.7) * 0.003).toFixed(4)}`
          );
          if (turbSm) {
            turbSm.setAttribute('baseFrequency',
              `${(0.018 + Math.sin(frame * 1.2) * 0.004).toFixed(4)} ${(0.02 + Math.cos(frame * 0.9) * 0.004).toFixed(4)}`
            );
          }
          if (running) requestAnimationFrame(tick);
        }

        const start = () => { if (!running) { running = true; tick(); } };
        const stop  = () => { running = false; };

        document.addEventListener('mouseenter', (e) => {
          if ((e.target as HTMLElement)?.closest?.('[data-liquid-glass]')) start();
        }, true);

        document.addEventListener('mouseleave', (e) => {
          if ((e.target as HTMLElement)?.closest?.('[data-liquid-glass]')) {
            setTimeout(() => {
              if (!document.querySelector('[data-liquid-glass]:hover')) stop();
            }, 50);
          }
        }, true);
      }

      if (document.readyState !== 'loading') {
        initLiquidGlass();
      } else {
        document.addEventListener('DOMContentLoaded', initLiquidGlass, { once: true });
      }
    </script>

  </body>
</html>