---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Work — Winds of Sinai">
  <main class="flex min-h-screen flex-col justify-center gap-10 px-8 py-28 md:px-16 lg:px-24">
    <div class="flex flex-col gap-3">
      <p class="text-xs tracking-[0.2em] uppercase" style="color: var(--c-gold-dim);">02 — Work</p>
      <h1 class="text-5xl md:text-7xl" style="font-family: var(--f-display); font-style: italic; font-weight: 300; color: var(--c-white);">
        Selected Work
      </h1>
      <p class="max-w-2xl text-sm md:text-base" style="color: var(--c-muted);">
        Transitional demo page for curtain + view transition. Open menu and move between Home and Work.
      </p>
    </div>

    <section class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <article class="p-6" style="border: 1px solid var(--c-border); background: var(--c-surface);">
        <p class="text-xs tracking-[0.2em] uppercase" style="color: var(--c-gold-dim);">Brand</p>
        <h2 class="mt-3 text-2xl" style="font-family: var(--f-display); font-style: italic; font-weight: 300; color: var(--c-white);">Maison Volta</h2>
      </article>
      <article class="p-6" style="border: 1px solid var(--c-border); background: var(--c-surface);">
        <p class="text-xs tracking-[0.2em] uppercase" style="color: var(--c-gold-dim);">Digital</p>
        <h2 class="mt-3 text-2xl" style="font-family: var(--f-display); font-style: italic; font-weight: 300; color: var(--c-white);">Atelier No.9</h2>
      </article>
      <article class="p-6" style="border: 1px solid var(--c-border); background: var(--c-surface);">
        <p class="text-xs tracking-[0.2em] uppercase" style="color: var(--c-gold-dim);">Campaign</p>
        <h2 class="mt-3 text-2xl" style="font-family: var(--f-display); font-style: italic; font-weight: 300; color: var(--c-white);">Obsidian House</h2>
      </article>
    </section>
  </main>
</Layout>
