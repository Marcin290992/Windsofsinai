---
import Layout from '../layouts/Layout.astro';
// @ts-ignore
import ctaBg from '../img/beduin-tent-scaled.webp';
---

<Layout title="Destynacje | Winds of Sinai">

  <main class="dp">

    <section class="dp-hero">
      <div class="dp-hero__img-wrap">
        <img class="dp-hero__img"
          src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?auto=format&fit=crop&w=2000&q=80"
          alt="Dahab" loading="eager" decoding="async" />
      </div>
      <div class="dp-hero__veil" aria-hidden="true"></div>
      <div class="dp-hero__copy">
        <p class="dp-hero__kicker">Dahab · Sinai Peninsula</p>
        <h1 class="dp-hero__title">Dahab</h1>
        <p class="dp-hero__sub">Rafy, wiatr i pustynia w najbardziej wyrafinowanym wydaniu.</p>
      </div>
    </section>

    <section class="dp-intro">
      <div class="dp-intro__left">
        <span class="dp-intro__label">Wprowadzenie</span>
        <h2 class="dp-intro__h">
          <span class="dp-intro__line"><span>Podróż,</span></span>
          <span class="dp-intro__line"><span>która płynie</span></span>
          <span class="dp-intro__line"><span>w Twoim tempie.</span></span>
        </h2>
      </div>
      <div class="dp-intro__right">
        <p class="dp-intro__body">
          Dahab to kontrast światła i ciszy: poranki na rafie, popołudnia wśród gór
          i wieczory, w których pustynia oddycha spokojem. Każdy dzień układamy
          prywatnie, z uwzględnieniem Twojego rytmu, komfortu i tego, co naprawdę chcesz poczuć.
        </p>
      </div>
    </section>

    <section class="dp-gallery">
      <figure class="dp-gal__item dp-gal__item--a" data-px="-22">
        <div class="dp-gal__wrap">
          <img class="dp-gal__img" loading="lazy" decoding="async"
            src="https://images.unsplash.com/photo-1559827260-dc66d52bef19?auto=format&fit=crop&w=1200&q=80"
            alt="Nurkowanie w Dahab" />
        </div>
      </figure>
      <figure class="dp-gal__item dp-gal__item--b" data-px="-34">
        <div class="dp-gal__wrap">
          <img class="dp-gal__img" loading="lazy" decoding="async"
            src="https://images.unsplash.com/photo-1473116763249-2faaef81ccda?auto=format&fit=crop&w=1200&q=80"
            alt="Pustynia Synaju" />
        </div>
      </figure>
      <figure class="dp-gal__item dp-gal__item--c" data-px="-18">
        <div class="dp-gal__wrap">
          <img class="dp-gal__img" loading="lazy" decoding="async"
            src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1200&q=80"
            alt="Góry Synaju" />
        </div>
      </figure>
    </section>

    <section class="dp-quote">
      <div class="dp-quote__rule"></div>
      <blockquote class="dp-quote__text">
        „Największy luksus to podróż, w której nic nie musisz,
        a wszystko jest dokładnie na swoim miejscu."
      </blockquote>
    </section>

    <section class="dp-cta">
      <img class="dp-cta__bg" src={ctaBg.src} alt="" loading="lazy" aria-hidden="true" />
      <div class="dp-cta__veil" aria-hidden="true"></div>
      <div class="dp-cta__copy">
        <span class="dp-cta__label">Twoja przygoda</span>
        <h2 class="dp-cta__title">
          <span>Zaplanuj swoją</span>
          <span>wyprawę na <em>Synaj</em></span>
        </h2>
        <p class="dp-cta__desc">
          Kolacja pod gwiazdami, nurkowanie w Dahabie, wschód słońca
          na szczycie Mojżesza — to dopiero początek.
        </p>
        <a href="mailto:hello@windsofsinai.com" class="dp-cta__btn">
          Napisz do nas <span aria-hidden="true">↗</span>
        </a>
      </div>
    </section>

  </main>

  <nav id="dp-dock" class="dp-dock" aria-label="Wybierz destynację"
    style="opacity:1;pointer-events:auto;">

    <!-- Mobile: compact prev/active/next -->
    <div class="dp-dock__mobile">
      <button class="dp-dock__arrow dp-dock__arrow--prev" type="button" aria-label="Poprzednia">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="dp-dock__current">
        <div class="dp-dock__current-inner">
          <span class="dp-dock__current-num">01</span>
          <span class="dp-dock__current-name">Dahab</span>
          <span class="dp-dock__current-count">/ 05</span>
        </div>
      </div>
      <button class="dp-dock__arrow dp-dock__arrow--next" type="button" aria-label="Następna">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
      <div class="dp-dock__sep" aria-hidden="true"></div>
      <button class="dp-dock__enquire" type="button" data-open-enquiry>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </button>
    </div>

    <!-- Desktop: all buttons -->
    <div class="dp-dock__desktop">
      <button class="dp-dock__btn is-active" data-region="dahab" type="button">
        <span class="dp-dock__num">01</span>
        <span class="dp-dock__name">Dahab</span>
      </button>
      <button class="dp-dock__btn" data-region="nuweiba" type="button">
        <span class="dp-dock__num">02</span>
        <span class="dp-dock__name">Nuweiba</span>
      </button>
      <button class="dp-dock__btn" data-region="ras-abu-galum" type="button">
        <span class="dp-dock__num">03</span>
        <span class="dp-dock__name">Ras Abu Galum</span>
      </button>
      <button class="dp-dock__btn" data-region="st-catherine" type="button">
        <span class="dp-dock__num">04</span>
        <span class="dp-dock__name">St. Catherine</span>
      </button>
      <button class="dp-dock__btn" data-region="taba" type="button">
        <span class="dp-dock__num">05</span>
        <span class="dp-dock__name">Taba Heights</span>
      </button>
      <div class="dp-dock__sep-desk" aria-hidden="true"></div>
      <button class="dp-dock__enquire-desk" type="button" data-open-enquiry>
        <span>Enquire</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
      </button>
    </div>
  </nav>

  <style is:global>
    .dp { position:relative; z-index:2; background:#FAF8F3; padding-bottom:3.8rem; }

    .dp-hero {
      position:sticky; top:0; z-index:0;
      height:calc(var(--vh,1vh)*100);
      overflow:hidden; display:grid; place-items:center; background:#0a0a0a;
    }
    .dp-hero__img-wrap { position:absolute; inset:-10% 0 0; height:120%; will-change:transform; }
    .dp-hero__img { width:100%; height:100%; object-fit:cover; display:block; }
    .dp-hero__veil { position:absolute; inset:0; background:linear-gradient(to bottom,rgba(6,6,6,.36),rgba(6,6,6,.62)); }
    .dp-hero__copy { position:relative; z-index:2; text-align:center; color:#fff; padding:0 1.2rem; max-width:58rem; }
    .dp-hero__kicker {
      display:inline-block; font-family:'IBM Plex Mono',monospace;
      font-size:.57rem; letter-spacing:.24em; text-transform:uppercase;
      color:rgba(255,255,255,.72); margin-bottom:1.1rem;
    }
    .dp-hero__title {
      font-family:'Cinzel Decorative',serif;
      font-size:clamp(3rem,8.5vw,7.5rem); font-weight:400; line-height:.92; letter-spacing:.025em; margin:0;
    }
    .dp-hero__sub {
      margin:1.3rem auto 0; max-width:30rem;
      font-family:'Cormorant Garamond',serif;
      font-size:clamp(1rem,1.9vw,1.3rem); font-style:italic; line-height:1.38; color:rgba(255,255,255,.88);
    }

    .dp-intro {
      position:relative; z-index:3;
      display:grid; grid-template-columns:1.1fr 1fr; gap:clamp(2rem,5vw,6rem);
      padding:clamp(5rem,9vw,9rem) clamp(1.5rem,6vw,6.5rem); background:#FAF8F3;
    }
    .dp-intro__label {
      display:inline-block; font-family:'IBM Plex Mono',monospace;
      font-size:.54rem; letter-spacing:.24em; text-transform:uppercase; color:#7D6945; margin-bottom:1.4rem;
    }
    .dp-intro__h {
      margin:0; font-family:'Cormorant Garamond',serif;
      font-size:clamp(2.3rem,5vw,4.7rem); font-style:italic; line-height:.94; letter-spacing:-.02em; color:#111;
    }
    .dp-intro__line { display:block; overflow:hidden; margin-bottom:.18em; }
    .dp-intro__line > span { display:block; clip-path:inset(0 0 100% 0); }
    .dp-intro__body {
      margin:0; font-family:'Cormorant Garamond',serif;
      font-size:clamp(1.08rem,1.55vw,1.34rem); line-height:1.72; color:rgba(17,17,17,.8);
    }

    .dp-gallery {
      position:relative; z-index:3;
      display:grid; grid-template-columns:1.1fr .9fr;
      grid-template-rows:minmax(18rem,38vw) minmax(16rem,27vw);
      gap:clamp(.9rem,2vw,1.6rem);
      padding:0 clamp(1.5rem,6vw,6.5rem) clamp(6rem,9vw,9rem); background:#FAF8F3;
    }
    .dp-gal__item { margin:0; min-width:0; }
    .dp-gal__item--a { grid-column:1/2; grid-row:1/3; }
    .dp-gal__item--b { grid-column:2/3; grid-row:1/2; }
    .dp-gal__item--c { grid-column:2/3; grid-row:2/3; }
    .dp-gal__wrap { position:relative; width:100%; height:100%; overflow:hidden; border-radius:2px; }
    .dp-gal__img {
      width:100%; height:138%; display:block; object-fit:cover; object-position:center;
      will-change:transform; transition:transform .55s cubic-bezier(.22,1,.36,1);
    }
    .dp-gal__wrap:hover .dp-gal__img { transform:scale(1.04); }

    .dp-quote {
      position:relative; z-index:3; background:#0A0A0A; color:#fff;
      text-align:center; padding:clamp(5rem,10vw,9rem) 1.5rem;
    }
    .dp-quote__rule {
      width:min(10rem,38vw); height:1px; background:#C8A96E;
      margin:0 auto clamp(1.8rem,3vw,2.8rem); transform:scaleX(0); transform-origin:center;
    }
    .dp-quote__text {
      margin:0 auto; max-width:50rem; font-family:'Cormorant Garamond',serif;
      font-size:clamp(1.75rem,4.1vw,3.4rem); font-style:italic; font-weight:300; line-height:1.15; letter-spacing:-.01em;
    }

    .dp-cta {
      position:relative; z-index:3; min-height:100vh;
      display:flex; align-items:center; justify-content:center; overflow:hidden;
    }
    .dp-cta__bg { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
    .dp-cta__veil { position:absolute; inset:0; background:linear-gradient(to bottom,rgba(9,9,9,.35) 0%,rgba(9,9,9,.55) 50%,rgba(9,9,9,.7) 100%); }
    .dp-cta__copy {
      position:relative; z-index:1; text-align:center; color:#fff;
      padding:clamp(3rem,6vw,6rem) clamp(1.5rem,4vw,3rem); max-width:48rem;
      display:flex; flex-direction:column; align-items:center; gap:1.5rem;
    }
    .dp-cta__label { font-family:'IBM Plex Mono',monospace; font-size:.54rem; letter-spacing:.24em; text-transform:uppercase; color:#C8A96E; }
    .dp-cta__title { font-family:'Cinzel Decorative',serif; font-size:clamp(2.2rem,5.5vw,4.5rem); font-weight:400; line-height:1.1; letter-spacing:.02em; margin:0; }
    .dp-cta__title span { display:block; }
    .dp-cta__title em { color:#C8A96E; font-style:italic; }
    .dp-cta__desc { font-family:'Cormorant Garamond',serif; font-size:clamp(.95rem,1.4vw,1.12rem); line-height:1.75; color:rgba(255,255,255,.75); max-width:34rem; margin:0; }
    .dp-cta__btn {
      display:inline-flex; align-items:center; gap:.5rem;
      font-family:'IBM Plex Mono',monospace; font-size:.6rem; letter-spacing:.2em;
      text-transform:uppercase; text-decoration:none; color:#fff;
      padding:.9rem 2.2rem; margin-top:.5rem;
      background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.18);
      border-radius:2px; backdrop-filter:blur(16px);
      transition:background .4s,border-color .4s,color .4s;
    }
    .dp-cta__btn:hover { background:rgba(255,255,255,.16); border-color:rgba(200,169,110,.5); color:#C8A96E; }

    /* ── DOCK ── */
    .dp-dock {
      position:fixed; bottom:1.4rem; left:50%; transform:translateX(-50%); z-index:10020;
      max-width:calc(100% - 2rem); width:max-content;
      background:rgba(10,10,10,.82);
      border:1px solid rgba(200,169,110,.15);
      border-radius:60px;
      padding:.35rem .45rem;
      backdrop-filter:blur(28px) saturate(160%);
      -webkit-backdrop-filter:blur(28px) saturate(160%);
      box-shadow:0 4px 32px rgba(0,0,0,.35), 0 0 0 .5px rgba(255,255,255,.06) inset;
      transition:transform .38s cubic-bezier(.22,1,.36,1), opacity .26s ease;
    }
    /* Desktop buttons wrapper */
    .dp-dock__desktop {
      display:flex; justify-content:center; gap:.35rem;
    }
    /* Mobile wrapper — hidden on desktop */
    .dp-dock__mobile { display:none; }

    .dp-dock__btn {
      flex:0 0 auto; display:flex; align-items:center; justify-content:center;
      gap:.45rem; border:0;
      background:transparent; padding:.6rem 1.1rem; cursor:pointer;
      border-radius:40px; min-width:7.2rem;
      transition:background .32s ease, box-shadow .32s ease;
    }
    .dp-dock__btn:hover { background:rgba(255,255,255,.06); }
    .dp-dock__btn.is-active {
      background:rgba(200,169,110,.88);
      box-shadow:0 2px 12px rgba(200,169,110,.25);
    }
    .dp-dock__num {
      font-family:'IBM Plex Mono',monospace; font-size:.42rem; letter-spacing:.12em;
      color:rgba(255,255,255,.28); transition:color .28s;
      flex-shrink:0;
    }
    .dp-dock__btn.is-active .dp-dock__num { color:rgba(17,17,17,.4); }
    .dp-dock__name {
      font-family:'IBM Plex Mono',monospace; font-size:.54rem; letter-spacing:.1em;
      text-transform:uppercase; color:rgba(255,255,255,.55);
      white-space:nowrap; transition:color .28s;
    }
    .dp-dock__btn.is-active .dp-dock__name { color:#111; font-weight:600; }
    .dp-dock__btn:hover:not(.is-active) .dp-dock__name { color:rgba(255,255,255,.85); }
    .dp-dock__btn:hover:not(.is-active) .dp-dock__num  { color:rgba(255,255,255,.4); }
    .dp-dock--hidden { transform:translateX(-50%) translateY(calc(100% + 2rem)) !important; }

    /* ── Dock: desktop enquire button ── */
    .dp-dock__sep-desk {
      width:1px; height:1.4rem; background:rgba(255,255,255,.1);
      margin:0 .15rem; flex-shrink:0; align-self:center;
    }
    .dp-dock__enquire-desk {
      flex:0 0 auto; display:flex; align-items:center; gap:.4rem;
      border:0; background:rgba(200,169,110,.14); color:rgba(200,169,110,.9);
      font-family:'IBM Plex Mono',monospace; font-size:.52rem; letter-spacing:.1em;
      text-transform:uppercase; font-weight:500;
      padding:.55rem 1rem; border-radius:40px; cursor:pointer; white-space:nowrap;
      transition:background .32s ease, color .32s ease, box-shadow .32s ease;
    }
    .dp-dock__enquire-desk:hover {
      background:rgba(200,169,110,.88); color:#111;
      box-shadow:0 2px 14px rgba(200,169,110,.3);
    }
    .dp-dock__enquire-desk:active { transform:scale(.97); }

    /* ── Mobile compact dock ── */
    @media (max-width:768px) {
      .dp-dock {
        bottom:1.8rem; left:50%; right:auto;
        transform:translateX(-50%); width:auto; max-width:calc(100% - 2rem);
        padding:.35rem .3rem;
        border-radius:52px;
      }
      .dp-dock--hidden { transform:translateX(-50%) translateY(calc(100% + 3rem)) !important; }
      .dp-dock__desktop { display:none; }
      .dp-dock__mobile {
        display:flex; align-items:center; gap:.1rem;
      }
      .dp-dock__arrow {
        display:flex; align-items:center; justify-content:center;
        width:2.4rem; height:2.4rem;
        border:0; border-radius:50%;
        background:transparent; color:rgba(255,255,255,.45);
        cursor:pointer; flex-shrink:0;
        transition:background .25s ease, color .25s ease;
      }
      .dp-dock__arrow:active { background:rgba(255,255,255,.1); color:#fff; }
      .dp-dock__current {
        display:flex; align-items:center; gap:.55rem;
        padding:.45rem 1rem;
        background:rgba(200,169,110,.88);
        border-radius:40px;
        min-width:9rem; justify-content:center;
        box-shadow:0 2px 12px rgba(200,169,110,.2);
        overflow:hidden; position:relative;
      }
      .dp-dock__current-inner {
        display:flex; align-items:center; gap:.55rem;
        transition:transform .3s cubic-bezier(.22,1,.36,1), opacity .3s ease;
      }
      .dp-dock__current-inner.is-out-left  { transform:translateX(-110%); opacity:0; }
      .dp-dock__current-inner.is-out-right { transform:translateX(110%);  opacity:0; }
      .dp-dock__current-inner.is-entering  { transition:none; }
      .dp-dock__current-num {
        font-family:'IBM Plex Mono',monospace; font-size:.44rem;
        letter-spacing:.1em; color:rgba(17,17,17,.35);
      }
      .dp-dock__current-name {
        font-family:'IBM Plex Mono',monospace; font-size:.6rem;
        letter-spacing:.1em; text-transform:uppercase;
        color:#111; font-weight:600; white-space:nowrap;
      }
      .dp-dock__current-count {
        font-family:'IBM Plex Mono',monospace; font-size:.4rem;
        letter-spacing:.06em; color:rgba(17,17,17,.3);
      }
      .dp-dock__sep {
        width:1px; height:1.6rem; background:rgba(255,255,255,.1);
        margin:0 .15rem; flex-shrink:0; align-self:center;
      }
      .dp-dock__enquire {
        display:flex; align-items:center; justify-content:center;
        width:2.6rem; height:2.6rem;
        border:0; border-radius:50%;
        background:rgba(200,169,110,.14); color:rgba(200,169,110,.8);
        cursor:pointer; flex-shrink:0;
        transition:background .3s ease, color .3s ease, box-shadow .35s ease, transform .3s cubic-bezier(.22,1,.36,1);
      }
      .dp-dock__enquire:hover { background:rgba(200,169,110,.25); color:#C8A96E; }
      .dp-dock__enquire:active {
        background:rgba(200,169,110,.35); transform:scale(.93);
        box-shadow:0 0 0 2px rgba(200,169,110,.2);
      }
    }

    @media (max-width:960px) {
      .dp-intro { grid-template-columns:1fr; gap:1.5rem; }
      .dp-gallery { grid-template-columns:1fr; grid-template-rows:auto; }
      .dp-gal__item--a,.dp-gal__item--b,.dp-gal__item--c { grid-column:auto; grid-row:auto; min-height:52svh; }
    }

    @media (max-width:560px) { .dp-cta { min-height:80vh; } }
  </style>

  <script is:inline>
  (function () {
    var REGIONS = {
      dahab: {
        kicker:'Dahab · Sinai Peninsula', title:'Dahab',
        sub:'Rafy, wiatr i pustynia w najbardziej wyrafinowanym wydaniu.',
        img:'https://images.unsplash.com/photo-1544551763-46a013bb70d5?auto=format&fit=crop&w=2000&q=80',
        alt:'Dahab',
        body:'Dahab to kontrast światła i ciszy: poranki na rafie, popołudnia wśród gór i wieczory, w których pustynia oddycha spokojem. Każdy dzień układamy prywatnie, z uwzględnieniem Twojego rytmu, komfortu i tego, co naprawdę chcesz poczuć.',
      },
      nuweiba: {
        kicker:'Nuweiba · Gulf of Aqaba', title:'Nuweiba',
        sub:'Długie plaże, spokój i prywatny rytm między morzem a górami.',
        img:'https://images.unsplash.com/photo-1511884642898-4c92249e20b6?auto=format&fit=crop&w=2000&q=80',
        alt:'Nuweiba',
        body:'Nuweiba to bardziej kontemplacyjna strona Synaju: poranki nad zatoką, kameralne kolacje na plaży i trasy 4x4 po pustynnych dolinach. Program budujemy spokojnie, z naciskiem na prywatność i oddech od codzienności.',
      },
      'ras-abu-galum': {
        kicker:'Ras Abu Galum · Protected Area', title:'Ras Abu Galum',
        sub:'Chronione rafy i surowa natura, dostępna tylko dla wtajemniczonych.',
        img:'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=2000&q=80',
        alt:'Ras Abu Galum',
        body:'Tutaj Synaj pokazuje swoją najbardziej naturalną twarz: kameralne zatoki, snorkeling w krystalicznej wodzie i przejazdy na wielbłądach wzdłuż wybrzeża. To kierunek dla gości, którzy szukają ciszy i autentyczności.',
      },
      'st-catherine': {
        kicker:'St. Catherine · High Sinai', title:'St. Catherine',
        sub:'Wysokie granie, klasztorna historia i poranki ponad chmurami.',
        img:'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=2000&q=80',
        alt:'St. Catherine',
        body:'Okolice St. Catherine łączą surową geografię wysokiego Synaju z niezwykłym dziedzictwem kulturowym. Organizujemy prywatne wejścia o świcie, postoje w ukrytych dolinach i trasy dopasowane do kondycji oraz tempa podróży.',
      },
      taba: {
        kicker:'Taba Heights · Red Sea Riviera', title:'Taba Heights',
        sub:'Panoramy zatoki i resortowy komfort w najbardziej eleganckiej formie.',
        img:'https://images.unsplash.com/photo-1519046904884-53103b34b206?auto=format&fit=crop&w=2000&q=80',
        alt:'Taba Heights',
        body:'Taba Heights to propozycja dla gości, którzy chcą połączyć komfort premium z aktywnym planem dnia. Rejsy, snorkeling, golf i prywatne transfery po regionie składamy w harmonijny, bezwysiłkowy program.',
      },
    };

    var _pxClean = null;
    var _dkClean = null;
    var _raf     = null;

    /* ── DOCK ─────────────────────────────────────────────────── */
    function initDock() {
      var dock = document.getElementById('dp-dock');
      var sw   = document.getElementById('scroll-wrapper');
      if (!dock) return null;

      var imgEl  = document.querySelector('.dp-hero__img');
      var kicker = document.querySelector('.dp-hero__kicker');
      var title  = document.querySelector('.dp-hero__title');
      var sub    = document.querySelector('.dp-hero__sub');
      var body   = document.querySelector('.dp-intro__body');
      var btns   = Array.from(dock.querySelectorAll('.dp-dock__btn'));

      /* mobile elements */
      var mNum   = dock.querySelector('.dp-dock__current-num');
      var mName  = dock.querySelector('.dp-dock__current-name');
      var mInner = dock.querySelector('.dp-dock__current-inner');
      var prevBtn = dock.querySelector('.dp-dock__arrow--prev');
      var nextBtn = dock.querySelector('.dp-dock__arrow--next');

      var KEYS = Object.keys(REGIONS);
      var currentIdx = 0;

      /* Preload all destination images */
      KEYS.forEach(function(k) {
        var img = new Image();
        img.src = REGIONS[k].img;
      });

      function show() {
        dock.style.opacity       = '1';
        dock.style.pointerEvents = 'auto';
        dock.classList.remove('dp-dock--hidden');
      }
      function hide() {
        dock.style.opacity       = '0';
        dock.style.pointerEvents = 'none';
        dock.classList.add('dp-dock--hidden');
      }

      show();

      var _slideDir = 0; /* -1 = prev, +1 = next, 0 = no anim */

      function syncMobile(key) {
        var idx = KEYS.indexOf(key);
        if (idx === -1) return;
        currentIdx = idx;

        if (!mInner || !mNum || !mName) {
          if (mNum)  mNum.textContent  = String(idx + 1).padStart(2, '0');
          if (mName) mName.textContent = REGIONS[key].title;
          return;
        }

        var dir = _slideDir;
        _slideDir = 0;

        if (dir === 0) {
          /* no animation (initial load / desktop click) */
          mNum.textContent  = String(idx + 1).padStart(2, '0');
          mName.textContent = REGIONS[key].title;
          return;
        }

        /* slide out in direction */
        mInner.classList.add(dir > 0 ? 'is-out-left' : 'is-out-right');

        function afterOut() {
          mInner.removeEventListener('transitionend', afterOut);
          /* update text */
          mNum.textContent  = String(idx + 1).padStart(2, '0');
          mName.textContent = REGIONS[key].title;
          /* jump to opposite side (no transition) */
          mInner.classList.remove('is-out-left', 'is-out-right');
          mInner.classList.add('is-entering', dir > 0 ? 'is-out-right' : 'is-out-left');
          /* force reflow */
          void mInner.offsetWidth;
          /* slide in */
          mInner.classList.remove('is-entering', 'is-out-left', 'is-out-right');
        }
        mInner.addEventListener('transitionend', afterOut, { once:true });
        /* safety timeout */
        setTimeout(function() { mInner.removeEventListener('transitionend', afterOut); afterOut(); }, 350);
      }

      var _transitioning = false;

      function go(key) {
        var d = REGIONS[key];
        if (!d || _transitioning) return;

        var g = window.gsap;
        var needsScroll = sw && sw.scrollTop > 80;

        /* If no GSAP or already at top — instant swap (no transition needed) */
        if (!needsScroll || !g) {
          applyRegion(key, d);
          return;
        }

        /* ── Full page transition ── */
        _transitioning = true;
        var strips = document.querySelectorAll('.pt-strip');
        var overlay = document.getElementById('pt-overlay');

        if (window.lenis) window.lenis.stop();

        /* Phase 1: cover with strips */
        g.killTweensOf('.pt-strip');
        g.set(strips, { scaleY:0, transformOrigin:'bottom center' });
        if (overlay) { overlay.style.pointerEvents = 'all'; }

        g.to(strips, {
          scaleY:1, duration:.5, ease:'sine.inOut', stagger:.08,
          onComplete:function() {
            /* Phase 2: hidden behind strips — reset scroll & update content */
            if (sw) sw.scrollTop = 0;
            if (window.lenis) window.lenis.scrollTo(0, { immediate:true });

            applyRegion(key, d);

            /* Phase 3: reveal — strips slide away */
            g.set(strips, { transformOrigin:'top center' });
            g.to(strips, {
              scaleY:0, duration:.65, ease:'sine.inOut', stagger:.08, delay:.06,
              onComplete:function() {
                if (overlay) overlay.style.pointerEvents = 'none';
                if (window.lenis) window.lenis.start();
                _transitioning = false;
              }
            });
          }
        });
      }

      function applyRegion(key, d) {
        btns.forEach(function(b) { b.classList.toggle('is-active', b.dataset.region === key); });
        if (kicker) kicker.textContent = d.kicker;
        if (title)  title.textContent  = d.title;
        if (sub)    sub.textContent    = d.sub;
        if (body)   body.textContent   = d.body;
        syncMobile(key);

        var g = window.gsap;
        if (imgEl && g) {
          g.set(imgEl, { opacity:0 });
          var prevSrc = imgEl.src;
          imgEl.src = d.img; imgEl.alt = d.alt;
          function fadeIn() {
            g.to(imgEl, { opacity:1, duration:.4, ease:'power2.out' });
          }
          if (imgEl.complete || imgEl.src === prevSrc) {
            fadeIn();
          } else {
            imgEl.addEventListener('load', fadeIn, { once:true });
          }
        } else if (imgEl) {
          imgEl.src = d.img; imgEl.alt = d.alt;
        }
      }

      /* Desktop click */
      function onClick(e) {
        var b = e.target.closest('.dp-dock__btn');
        if (b && b.dataset.region) go(b.dataset.region);
      }
      dock.addEventListener('click', onClick);

      /* Mobile arrows */
      function goPrev() {
        _slideDir = -1;
        currentIdx = (currentIdx - 1 + KEYS.length) % KEYS.length;
        go(KEYS[currentIdx]);
      }
      function goNext() {
        _slideDir = 1;
        currentIdx = (currentIdx + 1) % KEYS.length;
        go(KEYS[currentIdx]);
      }
      if (prevBtn) prevBtn.addEventListener('click', goPrev);
      if (nextBtn) nextBtn.addEventListener('click', goNext);

      /* Mobile swipe on dock */
      var _swX = 0;
      var _swLock = false;
      dock.addEventListener('touchstart', function(e) {
        _swX = e.touches[0].clientX;
        _swLock = false;
      }, { passive:true });
      dock.addEventListener('touchend', function(e) {
        if (_swLock) return;
        var dx = e.changedTouches[0].clientX - _swX;
        if (Math.abs(dx) > 30) {
          _swLock = true;
          if (dx < 0) goNext(); else goPrev();
        }
      }, { passive:true });

      /* ── wheel / touch na #scroll-wrapper ── */
      var target = sw || window;

      function onWheel(e) {
        if (e.deltaY >  3) hide();
        if (e.deltaY < -3) show();
      }

      var _ty = 0;
      function onTS(e) { _ty = e.touches[0].clientY; }
      function onTM(e) {
        var dy = _ty - e.touches[0].clientY;
        _ty = e.touches[0].clientY;
        if (dy >  8) hide();
        if (dy < -8) show();
      }

      function onKey(e) {
        if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') hide();
        if (e.key === 'ArrowUp'   || e.key === 'PageUp'   || e.key === 'Home') show();
      }

      function onScroll() {
        if (sw && sw.scrollTop < 80) show();
      }

      target.addEventListener('wheel',      onWheel, { passive:true });
      target.addEventListener('touchstart', onTS,    { passive:true });
      target.addEventListener('touchmove',  onTM,    { passive:true });
      if (sw) sw.addEventListener('scroll', onScroll, { passive:true });
      window.addEventListener('keydown', onKey);

      return function() {
        dock.removeEventListener('click', onClick);
        target.removeEventListener('wheel',      onWheel);
        target.removeEventListener('touchstart', onTS);
        target.removeEventListener('touchmove',  onTM);
        if (sw) sw.removeEventListener('scroll', onScroll);
        window.removeEventListener('keydown', onKey);
      };
    }

    /* ── HERO PARALLAX ─────────────────────────────────────────── */
    function initParallax() {
      var sw   = document.getElementById('scroll-wrapper');
      var hero = document.querySelector('.dp-hero');
      var wrap = document.querySelector('.dp-hero__img-wrap');
      var g    = window.gsap;
      if (!sw || !hero || !wrap || !g) return null;

      var MAX = 26;
      function upd() {
        var r = hero.getBoundingClientRect();
        var p = Math.min(1, Math.max(0, -r.top / Math.max(r.height, window.innerHeight)));
        g.set(wrap, { yPercent: -(MAX * p) });
      }

      sw.addEventListener('scroll', upd, { passive:true });
      window.addEventListener('resize', upd);
      requestAnimationFrame(upd);

      return function() {
        sw.removeEventListener('scroll', upd);
        window.removeEventListener('resize', upd);
        wrap.style.transform = '';
      };
    }

    /* ── SCROLL ANIMATIONS ─────────────────────────────────────── */
    function initAnims() {
      var g  = window.gsap;
      var ST = window.ScrollTrigger;
      if (!g || !ST) return;

      g.fromTo('.dp-hero__title',  {opacity:0,y:44}, {opacity:1,y:0,duration:1,  ease:'power3.out'});
      g.fromTo('.dp-hero__kicker', {opacity:0,y:28}, {opacity:1,y:0,duration:.9, ease:'power3.out',delay:.08});
      g.fromTo('.dp-hero__sub',    {opacity:0,y:28}, {opacity:1,y:0,duration:.9, ease:'power3.out',delay:.16});

      var lines = g.utils.toArray('.dp-intro__line > span');
      if (lines.length) {
        g.fromTo(lines,
          { clipPath:'inset(0 0 100% 0)' },
          { clipPath:'inset(0 0 0% 0)', duration:.95, ease:'power3.out', stagger:.12,
            scrollTrigger:{ trigger:'.dp-intro', scroller:'#scroll-wrapper', start:'top 85%' } }
        );
      }

      g.utils.toArray('.dp-gal__item').forEach(function(item) {
        var img = item.querySelector('.dp-gal__img');
        if (!img) return;
        var yP = Number(item.dataset.px || '-8');
        g.fromTo(img,
          { yPercent: Math.abs(yP) * .55 },
          { yPercent:yP, ease:'none',
            scrollTrigger:{ trigger:item, scroller:'#scroll-wrapper', start:'top 85%', end:'bottom top', scrub:true } }
        );
      });

      g.fromTo('.dp-quote__rule',
        { scaleX:0, transformOrigin:'center' },
        { scaleX:1, duration:1.2, ease:'power3.out',
          scrollTrigger:{ trigger:'.dp-quote', scroller:'#scroll-wrapper', start:'top 85%' } }
      );

      requestAnimationFrame(function() { ST.refresh(); });
    }

    /* ── INIT ──────────────────────────────────────────────────── */
    function init() {
      if (!document.getElementById('scroll-wrapper')) return;
      if (_pxClean) { _pxClean(); _pxClean = null; }
      if (_dkClean) { _dkClean(); _dkClean = null; }
      _pxClean = initParallax();
      _dkClean = initDock();
      initAnims();
    }

    function schedule() {
      if (_raf) cancelAnimationFrame(_raf);
      _raf = requestAnimationFrame(function() { init(); _raf = null; });
    }

    document.addEventListener('DOMContentLoaded', schedule);
    if (document.readyState !== 'loading') schedule();

  })();
  </script>

</Layout>